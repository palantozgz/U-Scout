{
  "name": "ucore-wcba-collector",
  "version": "1.0.0",
  "description": "WCBA stats collector for U Core — runs on Raspberry Pi 5",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "calibrate": "npx tsx src/sync/shotZones.ts"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "node-cron": "^3.0.3",
    "telegraf": "^4.16.3",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
